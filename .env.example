# Spotify Intelligence Copilot — Environment Variables
# Copy this file to .env and fill in your values

# FastAPI Server
API_BASE_URL=http://localhost:8000

# Optional: Groq LLM (for agent notebook)
# Get your key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Optional: ChromaDB Vector Store Settings
CHROMA_HOST=localhost
CHROMA_PORT=8000

# Logging & Debug
LOG_LEVEL=INFO
DEBUG=False

# Model Paths (usually auto-detected)
# MODEL_DIR=./models
# DATA_DIR=./data
